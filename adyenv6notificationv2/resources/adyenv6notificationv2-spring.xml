<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

	<bean id="defaultAdyenNotificationV2Service" class="com.adyen.v6.service.impl.DefaultAdyenNotificationV2Service">
		<property name="modelService" ref="modelService"/>
		<property name="eventService" ref="eventService"/>
	</bean>

    <bean id="tokenizationWebhookRequestConverter" class="com.adyen.v6.converter.TokenizationWebhookRequestConverter">
    </bean>

    <alias name="defaultAdyenTokenizationWebhookService" alias="adyenTokenizationWebhookService"/>
    <bean id="defaultAdyenTokenizationWebhookService" class="com.adyen.v6.service.impl.DefaultAdyenTokenizationWebhookService">
        <property name="eventService" ref="eventService"/>
        <property name="tokenWebhookRequestConverter" ref="tokenizationWebhookRequestConverter"/>
    </bean>

</beans>
