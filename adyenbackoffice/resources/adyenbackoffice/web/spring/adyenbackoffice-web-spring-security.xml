<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd
           http://www.springframework.org/schema/context
           http://www.springframework.org/schema/context/spring-context.xsd">

    <!-- Enable component scanning for authentication components -->
    <context:component-scan base-package="com.adyen.backoffice.service.impl" />
    <context:component-scan base-package="com.adyen.backoffice.controller" />
    <context:component-scan base-package="com.adyen.backoffice.filter" />


</beans>