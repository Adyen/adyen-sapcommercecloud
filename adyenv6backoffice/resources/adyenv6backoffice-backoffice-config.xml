<config xmlns="http://www.hybris.com/cockpit/config"
		xmlns:na="http://www.hybris.com/cockpitng/config/notifications"
		xmlns:lv="http://www.hybris.com/cockpitng/component/listView"
		xmlns:as="http://www.hybris.com/cockpitng/config/advancedsearch">

	<!-- adyenv6backoffice UI configuration should be provided here -->

	<!--<context component="component-code" module="adyenv6backoffice">-->
	<!--Please check documentation for code snippets for specific components-->
	<!--</context>-->

	<context component="cseditorareaactions" type="Order" merge-by="type">
		<y:actions xmlns:y="http://www.hybris.com/cockpit/config/hybris">
			<y:group qualifier="common" merge-mode="merge">
				<y:label>actiongroup.common</y:label>
				<y:action action-id="de.hybris.ordermanagementbackoffice.actions.order.cancelorderaction"
						  property="currentObject" merge-mode="remove"/>
				<y:action action-id="com.adyen.v6.backoffice.widgets.actions.adyencancelorderaction"
						  property="currentObject" merge-mode="append" position="1"/>
			</y:group>
		</y:actions>
	</context>

	<context merge-by="module" type="Order" component="editorareaactions">
		<y:actions xmlns:y="http://www.hybris.com/cockpit/config/hybris">
			<y:group qualifier="common">
				<y:label>actiongroup.common</y:label>
				<y:action action-id="com.adyen.v6.backoffice.widgets.actions.adyencaptureorderaction" property="currentObject"
						  output-property="currentObject" />
			</y:group>
		</y:actions>
	</context>

	<context component="notification-area" source="adyen-capture-message-source" merge-by="source">
		<na:notification-area>
			<na:notifications eventType="General" level="SUCCESS">
				<na:message>adyen.order.capture.succeed</na:message>
				<na:references linksEnabled="false"/>
			</na:notifications>
			<na:notifications eventType="General" level="FAILURE">
				<na:message>adyen.order.capture.failure</na:message>
				<na:references linksEnabled="false"/>
			</na:notifications>
		</na:notification-area>
	</context>


	<context merge-by="type" type="BaseStore" component="editor-area">
		<editorArea:editorArea xmlns:editorArea="http://www.hybris.com/cockpitng/component/editorArea">
			<editorArea:tab name="hmc.adyen">
				<editorArea:section name="hmc.adyen.account">
					<editorArea:attribute qualifier="adyenMerchantConfig"/>
					<editorArea:attribute qualifier="adyenMerchantAccount"/>
					<editorArea:attribute qualifier="adyenImmediateCapture"/>
					<editorArea:attribute qualifier="adyenRecurringContractMode"/>
					<editorArea:attribute qualifier="adyenTestMode"/>
					<editorArea:attribute qualifier="adyenGuestUserTokenization"/>
					<editorArea:attribute qualifier="adyenAllowedCards"/>
					<editorArea:attribute qualifier="adyenRegion"/>
				</editorArea:section>
				<editorArea:section name="hmc.adyen.api">
					<editorArea:attribute qualifier="adyenAPIEndpointPrefix"/>
					<editorArea:attribute qualifier="adyenAPIKey" editor="com.hybris.cockpitng.editor.defaultpassword"/>
					<editorArea:attribute qualifier="adyenClientKey" editor="com.hybris.cockpitng.editor.defaultpassword"/>
				</editorArea:section>
				<editorArea:section name="hmc.adyen.notifications">
					<editorArea:attribute qualifier="adyenNotificationUsername"/>
					<editorArea:attribute qualifier="adyenNotificationPassword" editor="com.hybris.cockpitng.editor.defaultpassword"/>
					<editorArea:attribute qualifier="adyenNotificationHMACKey"/>
				</editorArea:section>
				<editorArea:section name="hmc.adyen.expressPayments">
					<editorArea:attribute qualifier="expressPaymentConfig.googlePayExpressEnabledOnCart" editor="com.hybris.cockpitng.editor.defaultboolean"/>
					<editorArea:attribute qualifier="expressPaymentConfig.applePayExpressEnabledOnCart" editor="com.hybris.cockpitng.editor.defaultboolean"/>
					<editorArea:attribute qualifier="expressPaymentConfig.paypalExpressEnabledOnCart" editor="com.hybris.cockpitng.editor.defaultboolean"/>
					<editorArea:attribute qualifier="expressPaymentConfig.amazonPayExpressEnabledOnCart" editor="com.hybris.cockpitng.editor.defaultboolean"/>
					<editorArea:attribute qualifier="expressPaymentConfig.googlePayExpressEnabledOnProduct" editor="com.hybris.cockpitng.editor.defaultboolean"/>
					<editorArea:attribute qualifier="expressPaymentConfig.applePayExpressEnabledOnProduct" editor="com.hybris.cockpitng.editor.defaultboolean"/>
					<editorArea:attribute qualifier="expressPaymentConfig.paypalExpressEnabledOnProduct" editor="com.hybris.cockpitng.editor.defaultboolean"/>
					<editorArea:attribute qualifier="expressPaymentConfig.amazonPayExpressEnabledOnProduct" editor="com.hybris.cockpitng.editor.defaultboolean"/>
				</editorArea:section>
				<editorArea:section name="hmc.adyen.clicktopay">
					<editorArea:attribute qualifier="clickToPayLocale" />
				</editorArea:section>
				<editorArea:section name="hmc.adyen.amazonpay">
					<editorArea:attribute qualifier="amazonpayPublicKey"/>
					<editorArea:attribute qualifier="amazonpayEnvironment"/>
					<editorArea:attribute qualifier="amazonpayRegion"/>
				</editorArea:section>
				<editorArea:section name="hmc.adyen.advanced">
					<editorArea:attribute qualifier="adyenBoleto"/>
					<editorArea:attribute qualifier="adyenPaypalMerchantId"/>
					<editorArea:attribute qualifier="l2L3ESDEnabled"/>
				</editorArea:section>
				<editorArea:section name="hmc.adyen.installments">
					<editorArea:attribute qualifier="adyenInstallmentConfigs"/>
				</editorArea:section>
				<editorArea:section name="hmc.adyen.dataCollection">
					<editorArea:attribute qualifier="dataCollectionEnabled"/>
				</editorArea:section>
			</editorArea:tab>
		</editorArea:editorArea>
	</context>

	<context merge-by="type" type="AdyenInstallmentConfig" component="editor-area">
		<editorArea:editorArea xmlns:editorArea="http://www.hybris.com/cockpitng/component/editorArea">
			<editorArea:tab name="hmc.adyen.installments.config">
				<editorArea:section name="hmc.adyen.installments.config.general">
					<editorArea:attribute qualifier="country"/>
					<editorArea:attribute qualifier="enabled" editor="com.hybris.cockpitng.editor.defaultboolean"/>
				</editorArea:section>
				<editorArea:section name="hmc.adyen.installments.config.options">
					<editorArea:attribute qualifier="installmentOptions" editor="com.hybris.cockpitng.editor.defaulttext"/>
					<editorArea:attribute qualifier="installmentPlans" editor="com.hybris.cockpitng.editor.defaulttext"/>
					<editorArea:attribute qualifier="showInstallmentAmounts" editor="com.hybris.cockpitng.editor.defaulttext"/>
					<editorArea:attribute qualifier="showInstallmentPlans" editor="com.hybris.cockpitng.editor.defaulttext"/>
				</editorArea:section>
			</editorArea:tab>
		</editorArea:editorArea>
	</context>

	<context merge-by="type" type="CsTicket" component="editor-area">
		<editorArea:editorArea xmlns:editorArea="http://www.hybris.com/cockpitng/component/editorArea">
			<editorArea:tab name="hmc.adyen">
				<editorArea:section name="hmc.adyen.details">
					<editorArea:attribute qualifier="pspReference"/>
					<editorArea:attribute qualifier="originalReference"/>
					<editorArea:attribute qualifier="amount"/>
					<editorArea:attribute qualifier="currency"/>
				</editorArea:section>
			</editorArea:tab>
		</editorArea:editorArea>
	</context>

	<context type="Order" component="advanced-search" merge-by="type">
		<as:advanced-search>
			<as:field-list>
				<as:field name="adyenRiskScore"/>
			</as:field-list>
		</as:advanced-search>
	</context>

	<context merge-by="type" type="Order" component="listview">
		<lv:list-view>
			<lv:column qualifier="adyenRiskScore"/>
		</lv:list-view>
	</context>

</config>
