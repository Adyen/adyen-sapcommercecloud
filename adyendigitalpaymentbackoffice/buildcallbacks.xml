<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<project name="adyendigitalpaymentbackoffice_buildcallbacks">
    	
    <property name="adyendigitalpaymentbackofficeWebFragmentSrc" value="${ext.adyendigitalpaymentbackoffice.path}/resources/web-fragment.xml"/>
    	
    <property name="adyendigitalpaymentbackofficeWebFragmentDestJar" value="${ext.backoffice.path}/web/webroot/WEB-INF/lib/webfragmentExt_adyendigitalpaymentbackoffice.jar"/>
	
    <macrodef name="adyendigitalpaymentbackoffice_after_clean">
        		
        <sequential>
            			
            <adyendigitalpaymentbackoffice_remove_web_fragment/>
            		
        </sequential>
        	
    </macrodef>
    	
    <macrodef name="adyendigitalpaymentbackoffice_after_build">
        		
        <sequential>
            			
            <adyendigitalpaymentbackoffice_remove_web_fragment/>
            			
            <adyendigitalpaymentbackoffice_create_web_fragment/>
            		
        </sequential>
        	
    </macrodef>
    	
    <macrodef name="adyendigitalpaymentbackoffice_remove_web_fragment">
        		
        <sequential>
            			
            <if>
                				
                <available file="${adyendigitalpaymentbackofficeWebFragmentDestJar}"/>
                				
                <then>
                    					
                    <delete file="${adyendigitalpaymentbackofficeWebFragmentDestJar}"/>
                    				
                </then>
                			
            </if>
            		
        </sequential>
        	
    </macrodef>
    	
    <macrodef name="adyendigitalpaymentbackoffice_create_web_fragment">
        		
        <sequential>
            			
            <if>
                				
                <available file="${adyendigitalpaymentbackofficeWebFragmentSrc}"/>
                				
                <then>
                    					
                    <sequential>
                        						
                        <jar destfile="${adyendigitalpaymentbackofficeWebFragmentDestJar}">
                            							
                            <metainf file="${adyendigitalpaymentbackofficeWebFragmentSrc}"/>
                            						
                        </jar>
                        					
                    </sequential>
                    				
                </then>
                			
            </if>
            		
        </sequential>
        	
    </macrodef>
    	
    <patternset id="adyendigitalpaymentbackoffice.localization.pattern">
        		
        <!-- core and hmc  -->
        		
        <include name="**/*locales*_en.properties"/>
        		
        <exclude name="**/hmc/web/webroot/WEB-INF/classes/**/*"/>
        		
        <exclude name="**/unittest/**/*"/>
        		
        <!-- cockpit (ng) -->
        		
        <include name="**/i3-label_en.properties"/>
        		
        <include name="**/labels_en.properties"/>
        		
        <!-- messages -->
        		
        <include name="**/*messages_en.properties"/>
        		
        <include name="**/*messages.properties"/>
        		
        <!-- frontend properties files in WEB-INF/messages folder -->
        		
        <include name="**/WEB-INF/messages/*_en.properties"/>
        		
        <!-- csv and impex -->
        		
        <include name="**/*_en.csv"/>
        		
        <include name="**/*_en.impex"/>
        		
        <include name="**/lang-en.properties"/>
        		
        <!-- email localizations from yacceleratorcore -->
        		
        <include name="resources/**/messages/*_en.properties"/>
        		
        <!-- include validation messages -->
        		
        <include name="resources/**/ValidationMessages.properties"/>
        	
    </patternset>
    	
    <macrodef name="adyendigitalpaymentbackoffice_before_build">
		<sequential>
			<register_sass_extension extensionname="adyendigitalpaymentbackoffice"/>
			<register_sass_extension extensionname="adyendigitalpaymentbackoffice" resources="resources" destination=""/>
		</sequential>
	</macrodef>
    
</project>
