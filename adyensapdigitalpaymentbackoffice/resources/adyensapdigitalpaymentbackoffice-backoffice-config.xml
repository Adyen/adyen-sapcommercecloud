	<context merge-by="type" type="Order" component="editorareaactions" module="adyensapdigitalpaymentbackoffice" principal="commerce">
		<y:actions xmlns:y="http://www.hybris.com/cockpit/config/hybris">
			<y:group merge-mode="merge" qualifier="common">
				<y:label>actiongroup.common</y:label>
				<y:action action-id="com.adyen.sapdigitalpaymentbackoffice.widgets.actions.RetrieveCardWithDPA" property="currentObject"/>
				<y:action action-id="com.adyen.sapdigitalpaymentbackoffice.widgets.actions.RetrieveAuthWithDPA" property="currentObject"/>
